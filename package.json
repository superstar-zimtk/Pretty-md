{
  "name": "pretty-md",
  "version": "1.1.0",
  "description": "WhatsApp Bot",
  "main": "index.js",
  "scripts": {
    "start": "node webserver.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 webserver.js",
    "start:heroku": "node --max-old-space-size=512 --optimize-for-size webserver.js",
    "heroku-postbuild": "echo 'Build complete'",
    "cleanup": "node cleanup.js",
    "reset-session": "node reset-session.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "start:fresh": "npm run reset-session && npm start",
    "install:panel": "npm install --legacy-peer-deps",
    "install:force": "npm install --force",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docker:build": "docker build -t docker run -e SESSION_ID=$SESSION_ID pretty-md"
  },
  "keywords": [
    "whatsapp-bot"
  ],
  "author": "superstar",
  "license": "ISC",
